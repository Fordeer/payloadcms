# Public HTTPS URL assigned to the Payload service. Do not include a trailing slash.
NEXT_PUBLIC_SERVER_URL=https://cms.example.com

# Prebuilt image pulled by Coolify. Use a sha-* tag to pin a specific release.
PAYLOAD_IMAGE=ghcr.io/fordeer/payloadcms:main

# MongoDB connection string. In Coolify, use the internal connection string from
# a separate MongoDB resource on the same server/network.
DATABASE_URL=mongodb://payload:replace-with-a-password@mongodb-resource-host:27017/fordeer?authSource=admin

# Generate URL-safe production secrets with: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
PREVIEW_SECRET=replace-with-a-long-random-secret

# The variables below are used only with docker-compose.local.yml.
APP_PORT=3000
MONGO_INITDB_ROOT_USERNAME=payload
MONGO_INITDB_ROOT_PASSWORD=payload
MONGO_DATABASE=fordeer
